-- 极简调试：直接查看 GAS 返回了什么
local GAS_URL = "https://script.google.com/macros/library/d/1L_o-MWE4mCAuCtXCYXuahSnSRjI9IPZNzFS_5_a13pe4pF1MhO1OGej5/28"  -- 请替换
local HttpService = game:GetService("HttpService")

local req = syn and syn.request or http_request or request or (http and http.request)
if not req then error("无 HTTP 请求函数") end

local url = GAS_URL .. "?action=getPlayers"
local res = req({ Url = url, Method = "GET" })

print("📥 响应码:", res.StatusCode)
if res.StatusCode == 200 and res.Body then
    local data = HttpService:JSONDecode(res.Body)
    local players = data.players or {}
    print("📊 GAS 返回玩家数量:", #players)
    if #players > 0 then
        print("👤 第一位玩家:")
        for k, v in pairs(players[1]) do
            print("   ", k, "=", tostring(v))
        end
    else
        print("⚠️ 玩家列表为空")
    end
else
    print("❌ 请求失败:", res.Body)
end
