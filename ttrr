-- 极简上报测试脚本
local GAS_URL = "https://script.google.com/macros/s/AKfycbxr0VcunE41lyIar8Iq949W0LzlqJYSF8XfKkFCFhrNCkuQ4GtPQIK7NVivmQpI9V0RVA/exec"  -- 请确认是您最新部署的 URL

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local lp = Players.LocalPlayer

local req = syn and syn.request or http_request or request or (http and http.request)
if not req then error("无 HTTP 请求函数") end

-- 构造数据（完全模拟面板上报）
local data = {
    userId = lp.UserId,
    displayName = lp.DisplayName,
    username = lp.Name,
    status = "ALIVE",
    jobId = game.JobId,
    joinTime = os.time(),
    sheetIndex = lp.UserId % 10
}

local function buildJson(t)
    local parts = {}
    for k, v in pairs(t) do
        local vStr
        if type(v) == "string" then
            vStr = '"' .. v:gsub('"', '\\"') .. '"'
        elseif type(v) == "number" then
            vStr = tostring(v)
        else
            vStr = '""'
        end
        table.insert(parts, '"' .. k .. '":' .. vStr)
    end
    return "{" .. table.concat(parts, ",") .. "}"
end

local function urlEncode(s)
    local result = ""
    for i = 1, #s do
        local c = s:sub(i, i)
        local b = string.byte(c)
        if (b >= 48 and b <= 57) or (b >= 65 and b <= 90) or (b >= 97 and b <= 122) or c == '-' or c == '_' or c == '.' or c == '~' then
            result = result .. c
        else
            result = result .. string.format("%%%02X", b)
        end
    end
    return result
end

local json = buildJson(data)
local url = GAS_URL .. "?data=" .. urlEncode(json)

print("📤 发送写入请求... sheetIndex =", data.sheetIndex)
local result = req({ Url = url, Method = "GET" })
print("📥 响应码:", result.StatusCode)
print("📥 响应体:", result.Body)

if result.StatusCode == 200 and string.find(result.Body, "success") then
    print("✅ 写入请求成功！请立即打开试算表，检查工作表 '分流_" .. data.sheetIndex .. "' 的最后一行是否有您的数据。")
else
    print("❌ 写入失败，请检查 GAS 部署权限或试算表绑定。")
end
