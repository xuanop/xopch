-- 终极最小化测试：发送完全固定的 JSON 字符串
local GAS_URL = "https://script.google.com/macros/s/AKfycbw3zarYx2Y5Ekv127iZVAror2xzi_2_z7EeYqPcSTTcMg5qncJpU8M903IARqpWNK2Okg/exec"

-- 完全不依赖任何 Roblox 服务，纯手工构造请求
local req = syn and syn.request or http_request or request or (http and http.request)
if not req then
    print("❌ 无请求函数")
    return
end

-- 固定的测试 JSON（已经过 URL 编码）
local fixedJson = '{"userId":123,"displayName":"Test","username":"Test","status":"ALIVE","jobId":"test","joinTime":123456,"lastSeen":123456,"sheetIndex":0}'
local encoded = fixedJson:gsub("%W", function(c) return string.format("%%%02X", string.byte(c)) end)
local url = GAS_URL .. "?data=" .. encoded

print("📤 发送固定测试数据...")
local success, result = pcall(function() return req({ Url = url, Method = "GET" }) end)

if not success then
    print("❌ 请求失败:", result)
elseif result then
    print("📥 响应码:", result.StatusCode)
    print("📥 响应体:", result.Body)
else
    print("❌ 请求返回 nil")
end
