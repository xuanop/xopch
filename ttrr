-- 超簡化單次上報版（用於連通性測試成功後）
local GAS_URL = "https://script.google.com/macros/s/AKfycbw3zarYx2Y5Ekv127iZVAror2xzi_2_z7EeYqPcSTTcMg5qncJpU8M903IARqpWNK2Okg/exec"
local HttpService = game:GetService("HttpService")
local lp = game:GetService("Players").LocalPlayer

local data = {
    userId = lp.UserId,
    displayName = lp.DisplayName,
    username = lp.Name,
    status = "ALIVE",
    jobId = game.JobId,
    joinTime = os.time(),
    lastSeen = os.time(),
    sheetIndex = lp.UserId % 10
}

local json = HttpService:JSONEncode(data)
local url = GAS_URL .. "?data=" .. game:UrlEncode(json)

local req = syn and syn.request or http_request or request or (http and http.request)
if not req then error("無請求函數") end

print("📤 發送上報...")
local result = req({ Url = url, Method = "GET" })
print("📥 響應碼:", result.StatusCode)
print("📥 響應體:", result.Body)

if result.StatusCode == 200 then
    print("✅ 上報成功，請檢查試算表")
else
    print("❌ 上報失敗，請根據上述響應碼排查")
end
