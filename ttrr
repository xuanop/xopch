-- 最終測試：發送完整玩家數據到 GAS
local GAS_URL = "https://script.google.com/macros/s/AKfycbw3zarYx2Y5Ekv127iZVAror2xzi_2_z7EeYqPcSTTcMg5qncJpU8M903IARqpWNK2Okg/exec"  -- 請替換

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local lp = Players.LocalPlayer

-- 構造數據
local data = {
    userId = lp.UserId,
    displayName = lp.DisplayName,
    username = lp.Name,
    status = "ALIVE",
    jobId = game.JobId,
    joinTime = os.time(),
    lastSeen = os.time(),
    sheetIndex = lp.UserId % 10
}

local json = HttpService:JSONEncode(data)
local url = GAS_URL .. "?data=" .. game:UrlEncode(json)

print("📤 發送測試數據...")
print("URL 長度:", #url)

local req = syn and syn.request or http_request or request or (http and http.request)
if not req then error("找不到 HTTP 請求函數") end

local result = req({ Url = url, Method = "GET" })

print("📥 響應碼:", result.StatusCode)
print("📥 響應體:", result.Body)

if result.StatusCode == 200 and string.find(result.Body, "success") then
    print("🎉 成功！數據已寫入試算表，請檢查 Google Sheets。")
else
    print("❌ 寫入失敗，請檢查 GAS 代碼中的 doGet 邏輯。")
end
