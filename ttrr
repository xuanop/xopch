-- 读取调试脚本（给看不到自己的用户运行）
local GAS_URL = "https://script.google.com/macros/s/AKfycbxr0VcunE41lyIar8Iq949W0LzlqJYSF8XfKkFCFhrNCkuQ4GtPQIK7NVivmQpI9V0RVA/exec"

local HttpService = game:GetService("HttpService")
local lp = game:GetService("Players").LocalPlayer

local req = syn and syn.request or http_request or request or (http and http.request)
if not req then error("无 HTTP 请求函数") end

local url = GAS_URL .. "?action=getPlayers"
print("📤 用户", lp.Name, "正在请求玩家列表...")
local result = req({ Url = url, Method = "GET" })

print("📥 响应码:", result.StatusCode)
if result.StatusCode ~= 200 then
    print("❌ 请求失败，响应体:", result.Body)
    return
end

local data = HttpService:JSONDecode(result.Body)
local players = data.players or {}
print("📊 GAS 返回玩家总数:", #players)

local foundSelf = false
for i, p in ipairs(players) do
    if tonumber(p.userId) == lp.UserId then
        foundSelf = true
        print("✅ 在列表中找到自己！")
        print("   显示名:", p.displayName)
        print("   状态:", p.status)
        print("   lastUpdate:", p.lastUpdate)
        print("   jobId:", p.jobId)
    end
end

if not foundSelf then
    print("❌ 在返回的", #players, "个玩家中没有找到自己！")
    if #players > 0 then
        print("   列表中的玩家 ID：")
        for _, p in ipairs(players) do
            print("     -", p.userId, p.displayName)
        end
    else
        print("   列表为空。")
    end
end
