-- 诊断版：自检玩家列表获取与渲染
local function diagnostic()
    print("========== 診斷開始 ==========")
    print("1. 檢查緩存數據...")
    updateCache()
    task.wait(2)
    print("2. 當前緩存玩家數量:", #cachedPlayers)
    if #cachedPlayers > 0 then
        print("3. 緩存內容:")
        for i, info in ipairs(cachedPlayers) do
            print(string.format("   [%d] %s (ID:%s) lastUpdate:%s", i, tostring(info.username), tostring(info.userId), tostring(info.lastUpdate)))
        end
    else
        print("3. 緩存為空，嘗試直接請求GAS...")
        local url = GAS_URL .. "?action=getPlayers"
        local res = httpGet(url)
        if res and res.StatusCode == 200 and res.Body then
            local data = HttpService:JSONDecode(res.Body)
            local raw = data.players or {}
            print("4. GAS直接返回玩家數量:", #raw)
            if #raw > 0 then
                print("5. 示例數據:", raw[1].username, raw[1].lastUpdate)
            else
                print("5. GAS返回空列表，請檢查試算表是否有數據")
            end
        else
            print("4. GAS請求失敗，狀態碼:", res and res.StatusCode)
        end
    end
    print("========== 診斷結束 ==========")
end

-- 绑定到Tab键（临时覆盖原逻辑）
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == PANEL_KEY then
        diagnostic()
    end
end)

print("診斷模式已啟用，按Tab執行診斷")
