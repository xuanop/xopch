        lp.PlayerGui.E5_Admin_Panel.Enabled = not lp.PlayerGui.E5_Admin_Panel.Enabled
    end
end)

-- 角色重生时自动关闭面板（避免遮挡）
lp.CharacterAdded:Connect(function()
    local panel = lp.PlayerGui:FindFirstChild("E5_Admin_Panel")
    if panel then
        panel.Enabled = false
    end
end)

