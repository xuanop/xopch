local SCRIPT_START = os.time()
local function reportStatus()
    local data = {}
    pcall(function()
        data.userId = lp.UserId
        data.displayName = lp.DisplayName
        data.username = lp.Name
        local character = lp.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        if not character or not humanoid then
            data.status = "DEAD"
        else
            if humanoid.Health <= 0 or humanoid:GetState() == Enum.HumanoidStateType.Dead then
                data.status = "DEAD"
            else
                data.status = "ALIVE"
            end
        end
        data.jobId = game.JobId
        data.joinTime = SCRIPT_START
        data.sheetIndex = lp.UserId % 10
    end)
    if not data.userId then return end
    local json = buildJson(data)
    local url = GAS_URL .. "?data=" .. urlEncode(json)
    httpGet(url)
end

task.spawn(function()
    while true do
        reportStatus()
        task.wait(math.random(90, 120))
    end
end)

local uiRefreshLoop = nil
local function startUIRefresh()
    if uiRefreshLoop then return end
    uiRefreshLoop = task.spawn(function() while screenGui and screenGui.Enabled do renderPlayerList(); task.wait(1) end uiRefreshLoop = nil end)
end
local function stopUIRefresh()
    if uiRefreshLoop then task.cancel(uiRefreshLoop); uiRefreshLoop = nil end
end

UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == PANEL_KEY then
        screenGui.Enabled = not screenGui.Enabled
        if screenGui.Enabled then
            renderPlayerList()
            startUIRefresh()
            task.spawn(function() updateCache(); if screenGui.Enabled then renderPlayerList() end end)
        else
            stopUIRefresh()
        end
    end
end)

