local cachedPlayers = {}
local cacheLock = false

local function fetchOnlinePlayers()
    local url = GAS_URL .. "?action=getPlayers"
    local res = httpGet(url)
    if not res or res.StatusCode ~= 200 or not res.Body then return {} end
    local success, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not success then return {} end
    local rawPlayers = data.players or {}
    
    print("[診斷] GAS 返回玩家總數:", #rawPlayers)
    local unique = {}
    for _, p in ipairs(rawPlayers) do
        local uid = p.userId
        if uid then
            local pTime = p.lastUpdate or 0
            local eTime = unique[uid] and unique[uid].lastUpdate or 0
            if not unique[uid] or pTime > eTime then unique[uid] = p end
        end
    end
    local final = {}
    for _, p in pairs(unique) do table.insert(final, p) end
    
    print("[診斷] 去重後玩家數量:", #final)
    for i, p in ipairs(final) do
        local lastUp = tonumber(p.lastUpdate) or 0
        local diff = os.time() - lastUp
        print(string.format("  [%d] %s (ID:%s) lastUpdate:%s diff:%d秒",
            i, tostring(p.username), tostring(p.userId), tostring(lastUp), diff))
    end
    
    table.sort(final, function(a, b) return (a.joinTime or 0) > (b.joinTime or 0) end)
    return final
end

local function updateCache()
    if cacheLock then return false end
    cacheLock = true
    local success, newData = pcall(fetchOnlinePlayers)
    cachedPlayers = success and newData or {}
    cacheLock = false
    return success
end

local function renderPlayerList()
    for _, child in ipairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    local now = os.time()
    local visibleCount = 0
    for _, info in ipairs(cachedPlayers) do
        local success = pcall(function()
            local userId = tonumber(info.userId)
            local isSelf = (userId == lp.UserId)
            local lastUpdate = tonumber(info.lastUpdate) or now
            local diff = now - lastUpdate
            local isOnline = (diff <= 180)  -- 放宽至180秒，与GAS一致

            if isSelf or isOnline then
                visibleCount = visibleCount + 1
                local btn = Instance.new("TextButton", playerList)
                btn.Size = UDim2.new(1, 0, 0, 130)
                btn.BackgroundColor3 = (info.jobId == game.JobId) and Color3.fromHex("4A306D") or Color3.fromRGB(35, 35, 45)
                btn.BackgroundTransparency = 0.2
                btn.ZIndex = 10
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

                local baseTime = isOnline and tonumber(info.joinTime) or lastUpdate
                baseTime = baseTime or now
                local diffTime = math.max(0, now - baseTime)
                local d = math.floor(diffTime / 86400)
                local h = math.floor((diffTime % 86400) / 3600)
                local m = math.floor((diffTime % 3600) / 60)
                local s = math.floor(diffTime % 60)

                local statusText = isOnline and (info.status ~= "" and info.status or "ALIVE") or "OFFLINE"
                local timerText = isOnline and string.format("⏱️ %dd %dh %dm %ds", d, h, m, s)
                                            or string.format("💤 離線 %dd %dh %dm %ds", d, h, m, s)

                btn.Text = string.format("👤 %s\n(@%s)\nID: %s\nStatus: %s\n%s",
                    tostring(info.displayName), tostring(info.username), tostring(userId), tostring(statusText), timerText)
                btn.TextColor3 = isOnline and Color3.new(1, 1, 1) or Color3.fromRGB(180, 180, 180)
                btn.TextSize = 15
                btn.Font = Enum.Font.GothamBold
                btn.TextWrapped = true

                local lastClick = 0
                btn.MouseButton1Click:Connect(function()
                    local t = tick()
                    if t - lastClick < 0.35 then
                        if isOnline and info.jobId and info.jobId ~= "" and info.jobId ~= game.JobId then
                            showNotice("正在追蹤玩家...")
                            safeTeleport(userId, info.jobId)
                        elseif not isOnline then
                            showNotice("❌ 玩家已離線，無法追蹤")
                        end
                    else
                        if setclipboard then setclipboard(tostring(userId)); showNotice("已複製 ID: " .. userId) end
                    end
                    lastClick = t
                end)
            end
        end)
        if not success then warn("渲染玩家失敗") end
    end
    if visibleCount == 0 then
        local emptyBtn = Instance.new("TextButton", playerList)
        emptyBtn.Size = UDim2.new(1, 0, 0, 50)
        emptyBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
        emptyBtn.Text = "😴 暫無在線玩家"
        emptyBtn.TextColor3 = Color3.new(1, 1, 1)
        emptyBtn.Font = Enum.Font.GothamMedium
        emptyBtn.TextSize = 16
        emptyBtn.ZIndex = 10
        Instance.new("UICorner", emptyBtn).CornerRadius = UDim.new(0, 6)
    end
end

