-- ==================== 通用工具函數 ====================
local function buildJson(t)
    local parts = {}
    for k, v in pairs(t) do
        local vStr
        if type(v) == "string" then vStr = '"' .. v:gsub('"', '\\"') .. '"'
        elseif type(v) == "number" then vStr = tostring(v)
        else vStr = '""' end
        table.insert(parts, '"' .. k .. '":' .. vStr)
    end
    return "{" .. table.concat(parts, ",") .. "}"
end

local function urlEncode(s)
    local result = ""
    for i = 1, #s do
        local c = s:sub(i, i)
        local b = string.byte(c)
        if (b >= 48 and b <= 57) or (b >= 65 and b <= 90) or (b >= 97 and b <= 122) or c == '-' or c == '_' or c == '.' or c == '~' then
            result = result .. c
        else
            result = result .. string.format("%%%02X", b)
        end
    end
    return result
end

local function httpGet(url)
    local success, result = pcall(function()
        return syn.request({
            Url = url,
            Method = "GET",
            Headers = {
                ["Cache-Control"] = "no-cache, no-store, must-revalidate",
                ["Pragma"] = "no-cache",
                ["Expires"] = "0"
            }
        })
    end)
    if not success then
        warn("[httpGet] syn.request 调用失败，尝试备用函数...")
        local req2 = http_request or request
        if req2 then
            success, result = pcall(function() return req2({ Url = url, Method = "GET" }) end)
            if not success then
                warn("[httpGet] 备用函数也失败")
                return nil
            end
        else
            return nil
        end
    end
    if result and result.StatusCode == 200 then
        return result
    else
        warn("[httpGet] 状态码异常:", result and result.StatusCode, "URL:", url)
        return nil
    end
end

