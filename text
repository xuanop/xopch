-- 智能傳送
local function safeTeleport(targetUserId, targetJobId)
    if targetJobId == game.JobId then showNotice("⚠️ 您已在該伺服器中"); return false end
    local success, placeId, jobId = pcall(function() return TeleportService:GetPlayerPlaceInstanceAsync(targetUserId) end)
    if not success then showNotice("❌ 伺服器不可用或玩家不存在"); return false end
    if not jobId or jobId == "" then showNotice("👻 玩家已離線"); return false end
    showNotice("🚀 正在傳送到玩家所在伺服器...")
    local teleportSuccess = pcall(function() TeleportService:TeleportToPlaceInstance(placeId, jobId, lp) end)
    if not teleportSuccess then
        showNotice("⚠️ 精準傳送失敗，嘗試普通傳送...")
        pcall(function() TeleportService:Teleport(placeId, lp) end)
    end
    return true
end

