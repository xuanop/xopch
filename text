-- ==================== 狀態上報（所有人執行） ====================
local SCRIPT_START = os.time()

local function reportStatus()
    local status = "ALIVE"
    if lp.Character then
        local humanoid = lp.Character:FindFirstChild("Humanoid")
        local isDowned = lp.Character:GetAttribute("Downed")
        local state = lp.Character:GetAttribute("State") or ""
        if isDowned or state == "Downed" then
            status = "DOWNED"
        elseif humanoid and (humanoid.Health <= 0 or humanoid:GetState() == Enum.HumanoidStateType.Dead) then
            status = "DEAD"
        end
    else
        status = "DEAD"
    end

    local data = {
        userId = lp.UserId,
        displayName = lp.DisplayName,
        username = lp.Name,
        status = status,
        jobId = game.JobId,
        joinTime = SCRIPT_START,
        lastUpdate = os.time(),
        sheetIndex = lp.UserId % 10
    }

    local json = buildJson(data)
    local url = GAS_URL .. "?data=" .. urlEncode(json)
    httpGet(url)
    print("📤 上報狀態：", status, "｜ 時間：", os.time())
end

-- 角色生成及復活時立即上報
lp.CharacterAdded:Connect(function(character)
    task.wait(0.5)
    reportStatus()
    local humanoid = character:WaitForChild("Humanoid")
    local lastHealth = humanoid.Health
    humanoid.HealthChanged:Connect(function(newHealth)
        if lastHealth <= 0 and newHealth > 0 then
            task.wait(0.2)
            reportStatus()
        end
        lastHealth = newHealth
    end)
    humanoid.Died:Connect(function()
        reportStatus()
    end)
end)

