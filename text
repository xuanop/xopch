    if gameProcessed then return end
    if input.KeyCode == PANEL_KEY then
        local newState = not screenGui.Enabled
        screenGui.Enabled = newState
        if newState then
            -- 1. 立即用現有緩存渲染（內部會自動過濾超時玩家）
            renderPlayerList()
            -- 2. 後台強制更新一次緩存，完成後若面板仍開啟則刷新 UI
            task.spawn(function()
                updateCache()
                if screenGui.Enabled then
                    renderPlayerList()
                end
            end)
        end
    end
end)

