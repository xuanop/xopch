-- ==================== 玩家列表緩存 ====================
local cachedPlayers = {}  -- 缓存最新的玩家列表
local cacheLock = false   -- 简单的防并发标志

-- ==================== 從 GAS 獲取在線玩家（强制去重版） ====================
local function fetchOnlinePlayers()
    local url = GAS_URL .. "?action=getPlayers"
    local res = httpGet(url)
    if res and res.Body then
        local data = HttpService:JSONDecode(res.Body)
        local rawPlayers = data.players or {}
        
        -- 使用 userId 作为唯一键进行去重，保留最新记录
        local uniquePlayers = {}
        for _, player in ipairs(rawPlayers) do
            local uid = player.userId
            if uid then
                -- 如果该玩家还不存在，或者当前记录比已存在的更新，则更新
                if not uniquePlayers[uid] or (player.lastUpdate or 0) > (uniquePlayers[uid].lastUpdate or 0) then
                    uniquePlayers[uid] = player
                end
            end
        end

        -- 将去重后的结果转换为数组格式
        local finalPlayers = {}
        for _, player in pairs(uniquePlayers) do
            table.insert(finalPlayers, player)
        end
        
        return finalPlayers
    end
    return {}
end

-- ==================== 更新緩存（後台執行） ====================
local function updateCache()
    if cacheLock then return end
    cacheLock = true
    local newData = fetchOnlinePlayers()
    if #newData > 0 then
        cachedPlayers = newData
    end
    cacheLock = false
end

-- ==================== 刷新 UI（使用緩存數據） ====================
local function renderPlayerList()
    -- 清空現有按鈕
    for _, child in ipairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local now = os.time()
    for _, info in ipairs(cachedPlayers) do
        local btn = Instance.new("TextButton", playerList)
        btn.Size = UDim2.new(1, 0, 0, 130)
        btn.BackgroundColor3 = (info.jobId == game.JobId) and Color3.fromHex("4A306D") or Color3.fromRGB(35, 35, 45)
        btn.BackgroundTransparency = 0.2
        btn.ZIndex = 10
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

        local join = tonumber(info.joinTime) or now
        local diff = math.max(0, now - join)
        local d = math.floor(diff / 86400)
        local h = math.floor((diff % 86400) / 3600)
        local m = math.floor((diff % 3600) / 60)
        local s = math.floor(diff % 60)

        btn.Text = string.format("👤 %s\n(@%s)\nID: %s\nStatus: %s\n⏱️ %dd %dh %dm %ds",
            info.displayName or "N/A", info.username or "N/A", info.userId or "N/A",
            info.status or "ALIVE", d, h, m, s)
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.TextSize = 15
        btn.Font = Enum.Font.GothamBold
        btn.TextWrapped = true

        local lastClick = 0
        btn.MouseButton1Click:Connect(function()
        local t = tick()
        if t - lastClick < 0.35 then
            if info.jobId and info.jobId ~= "" and info.jobId ~= game.JobId then
                showNotice("正在追蹤玩家...")
                -- 使用安全传送函数替代原来的 TeleportService:TeleportToPlaceInstance
                safeTeleport(info.userId, info.jobId)  -- 传入 userId 和 jobId
            end
        else
                if setclipboard then
                    setclipboard(tostring(info.userId))
                    showNotice("已複製 ID: " .. info.userId)
                end
            end
            lastClick = t
        end)
    end
end

-- ==================== 後台定時刷新緩存 ====================
task.spawn(function()
    -- 首次啟動時立即加載一次
    updateCache()
    while true do
        task.wait(5)  -- 每5秒更新一次緩存
        updateCache()
        -- 如果面板正在顯示，則刷新 UI
        if screenGui.Enabled then
            renderPlayerList()
        end
    end
end)

-- ==================== 狀態上報 ====================
local SCRIPT_START = os.time()
local function reportStatus()
    local data = {}
    pcall(function()
        data.userId = lp.UserId
        data.displayName = lp.DisplayName
        data.username = lp.Name
        data.status = "ALIVE"
        if lp.Character and lp.Character:FindFirstChild("Humanoid") then
            local hum = lp.Character.Humanoid
            if hum.Health <= 0 or hum:GetState() == Enum.HumanoidStateType.Dead then
                data.status = "DEAD"
            end
        end
        data.jobId = game.JobId
        data.joinTime = SCRIPT_START
        data.sheetIndex = lp.UserId % 10
    end)
    if not data.userId then return end
    local json = buildJson(data)
    local url = GAS_URL .. "?data=" .. urlEncode(json)
    httpGet(url)
end

task.spawn(function()
    while true do
        reportStatus()
        task.wait(30)
    end
end)

-- ==================== Tab 鍵切換（即時同步版） ====================
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == PANEL_KEY then
        local newState = not screenGui.Enabled
        screenGui.Enabled = newState
        if newState then
            -- 1. 立即用現有緩存渲染，保證瞬間顯示
            renderPlayerList()
            -- 2. 後台強制更新一次緩存，完成後再次刷新 UI
            task.spawn(function()
                updateCache()
                -- 更新期間如果面板沒有被關閉，則刷新顯示
                if screenGui.Enabled then
                    renderPlayerList()
                end
            end)
        end
    end
end)

