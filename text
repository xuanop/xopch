-- ==================== 增強版傳送 ====================
local function safeTeleport(targetUserId, targetJobId)
    print("[傳送] 目標 UserId:", targetUserId)
    print("[傳送] 目標 JobId:", targetJobId)
    print("[傳送] 當前 JobId:", game.JobId)

    -- 檢查目標 JobId 是否有效
    if not targetJobId or targetJobId == "" then
        showNotice("❌ 目標伺服器資訊無效")
        return false
    end

    -- 檢查是否已在同一伺服器
    if targetJobId == game.JobId then
        showNotice("⚠️ 您已在該伺服器中")
        return false
    end

    showNotice("🚀 正在傳送到玩家所在伺服器...")
    
    -- 直接使用儲存的 JobId 進行精準傳送
    local success, err = pcall(function()
        TeleportService:TeleportToPlaceInstance(game.PlaceId, targetJobId, lp)
    end)

    if success then
        return true
    end

    -- 若精準傳送失敗（例如伺服器已滿），提示並複製 ID
    warn("[傳送] 傳送失敗:", err)
    showNotice("❌ 傳送失敗，玩家可能已離線或伺服器已滿")
    
    if setclipboard then
        setclipboard(tostring(targetUserId))
        showNotice("📋 玩家 ID 已複製，可手動搜尋加入")
    end
    
    return false
end

