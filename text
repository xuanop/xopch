-- ==================== 純手工 JSON 構建 ====================
local function buildJson(t)
    local parts = {}
    for k, v in pairs(t) do
        local vStr
        if type(v) == "string" then
            vStr = '"' .. v:gsub('"', '\\"') .. '"'
        elseif type(v) == "number" then
            vStr = tostring(v)
        else
            vStr = '""'
        end
        table.insert(parts, '"' .. k .. '":' .. vStr)
    end
    return "{" .. table.concat(parts, ",") .. "}"
end

-- ==================== 純手工 URL 編碼 ====================
local function urlEncode(s)
    local result = ""
    for i = 1, #s do
        local c = s:sub(i, i)
        local b = string.byte(c)
        if (b >= 48 and b <= 57) or (b >= 65 and b <= 90) or (b >= 97 and b <= 122) or c == '-' or c == '_' or c == '.' or c == '~' then
            result = result .. c
        else
            result = result .. string.format("%%%02X", b)
        end
    end
    return result
end

-- ==================== HTTP 請求封裝 ====================
local function httpGet(url)
    local req = syn and syn.request or http_request or request or (http and http.request)
    if not req then return nil end
    local success, result = pcall(function() return req({ Url = url, Method = "GET" }) end)
    return success and result or nil
end

-- ==================== 智能傳送（區分離線與伺服器不可用） ====================
local function safeTeleport(targetUserId, targetJobId)
    local TeleportService = game:GetService("TeleportService")
    local lp = Players.LocalPlayer
    
    if targetJobId == game.JobId then
        showNotice("⚠️ 您已在該伺服器中")
        return false
    end
    
    local success, placeId, jobId = pcall(function()
        return TeleportService:GetPlayerPlaceInstanceAsync(targetUserId)
    end)
    
    if not success then
        showNotice("❌ 伺服器不可用或玩家不存在")
        task.spawn(function()
            updateCache()
            if screenGui.Enabled then renderPlayerList() end
        end)
        return false
    end
    
    if not jobId or jobId == "" then
        showNotice("👻 玩家已離線")
        task.spawn(function()
            updateCache()
            if screenGui.Enabled then renderPlayerList() end
        end)
        return false
    end
    
    showNotice("🚀 正在傳送到玩家所在伺服器...")
    local teleportSuccess, err = pcall(function()
        TeleportService:TeleportToPlaceInstance(placeId, jobId, lp)
    end)
    
    if teleportSuccess then
        return true
    else
        warn("精準傳送失敗: ", err)
        showNotice("⚠️ 精準傳送失敗，嘗試普通傳送...")
        local fallbackSuccess = pcall(function()
            TeleportService:Teleport(placeId, lp)
        end)
        if fallbackSuccess then
            return true
        else
            showNotice("❌ 傳送失敗，請重試")
            return false
        end
    end
end

