-- ==================== 狀態上報 ====================
local SCRIPT_START = os.time()
local function reportStatus()
    local data = {}
    pcall(function()
        data.userId = lp.UserId
        data.displayName = lp.DisplayName
        data.username = lp.Name
        data.status = "ALIVE"
        if lp.Character and lp.Character:FindFirstChild("Humanoid") then
            local hum = lp.Character.Humanoid
            if hum.Health <= 0 or hum:GetState() == Enum.HumanoidStateType.Dead then
                data.status = "DEAD"
            end
        end
        data.jobId = game.JobId
        data.joinTime = SCRIPT_START
        data.sheetIndex = lp.UserId % 10
    end)
    if not data.userId then return end
    local json = buildJson(data)
    local url = GAS_URL .. "?data=" .. urlEncode(json)
    httpGet(url)
end

task.spawn(function()
    while true do
        reportStatus()
        task.wait(30)
    end
end)

