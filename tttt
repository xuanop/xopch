local function findSafeSkyPosition()
    local highestY = 100
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Position.Y > highestY then
            highestY = obj.Position.Y
        end
    end
    local offsetY = 20   -- 固定在地图最高点上方 20 格
    local offsetX = 0    -- 水平 X 方向不偏移
    local offsetZ = 0    -- 水平 Z 方向不偏移
    return Vector3.new(offsetX, highestY + offsetY, offsetZ)
end

local function smoothTeleport(targetPos)
    if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = lp.Character.HumanoidRootPart
    local distance = (hrp.Position - targetPos).Magnitude
    if distance > 200 then
        hrp.CFrame = CFrame.new(targetPos)
        return
    end
    if farmTween then farmTween:Cancel() end
    local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local goal = { CFrame = CFrame.new(targetPos) }
    farmTween = TweenService:Create(hrp, tweenInfo, goal)
    farmTween:Play()
end

