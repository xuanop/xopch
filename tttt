function sendBroadcast(message)
    if message == "" then
        if showNotice then showNotice("⚠️ 消息不能为空", true) end
        return
    end
    local url = GAS_BROADCAST_URL .. "?action=sendBroadcast&msg=" .. urlEncode(message) .. "&sender=" .. urlEncode(lp.Name)
    print("[广播] 发送 URL:", url)
    local res = broadcastHttpRequest("GET", url, nil)
    if res then
        print("[广播] 响应码:", res.StatusCode)
        print("[广播] 原始响应体:", res.Body)
        -- 终极宽容判断：只要响应码为 200，就视为成功
        if res.StatusCode == 200 then
            if showNotice then showNotice("✅ 广播已发送", true) end
        else
            if showNotice then showNotice("❌ 广播发送失败（HTTP " .. res.StatusCode .. "）", true) end
        end
    else
        if showNotice then showNotice("❌ 广播发送失败（网络错误）", true) end
    end
end

