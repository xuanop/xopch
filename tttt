local function applyHeadlessToCharacter(char)
    if not char then return end

    task.spawn(function()
        local head = char:WaitForChild("Head", 10)
        if not head then return end
        task.wait(0.2)

        for _, obj in ipairs(head:GetChildren()) do
            if obj:IsA("Decal") or obj:IsA("Texture") then
                obj.Transparency = 1
            end
        end

        if head:IsA("MeshPart") then
            head.Transparency = 1 
        else
            local mesh = head:FindFirstChildOfClass("SpecialMesh")
            if not mesh then
                mesh = Instance.new("SpecialMesh", head)
            end
            if mesh then
                mesh.MeshId = HEADLESS_MESH_ID
                mesh.TextureId = ""
                mesh.Scale = Vector3.new(1, 1, 1)
                head.Transparency = 0 
            end
        end
    end)
end

local function resetHeadlessForCharacter(char)
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    for _, obj in ipairs(head:GetChildren()) do
        if obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 0
        end
    end

    if head:IsA("MeshPart") then
        head.Transparency = 0
    else
        local mesh = head:FindFirstChildOfClass("SpecialMesh")
        if mesh then
            mesh.MeshId = ""
            mesh.TextureId = ""
            mesh.Scale = Vector3.new(1, 1, 1)
        end
        head.Transparency = 0
    end
end

local function setupHeadlessForPlayer(player)
    if headlessEnabled and player.Character then
        applyHeadlessToCharacter(player.Character)
    end
    player.CharacterAdded:Connect(function(char)
        if headlessEnabled then
            applyHeadlessToCharacter(char)
        end
    end)
end

