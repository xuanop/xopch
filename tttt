    if not toxic then
        warn("[MyCommander] 找不到 Toxic Inferno 装饰品")
        return
    end

    local cloned = toxic:Clone()
    cloned.Name = "ToxicInferno_Applied"

    if cloned:IsA("Accessory") then
        cloned.Parent = character
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:AddAccessory(cloned)
        end
    else
        cloned.Parent = character
    end

    print("[MyCommander] Toxic Inferno 已应用")
end

