-- ==================== 自动救助倒地队友（前置定义） ====================
local autoRescueEnabled = false
local isRescuing = false
local rescueConnection = nil

function getDownedPlayers()
    local downedList = {}
    local gameFolder = workspace:FindFirstChild("Game")
    local playersFolder = gameFolder and gameFolder:FindFirstChild("Players")
    if not playersFolder then return downedList end
    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        local character = playersFolder:FindFirstChild(player.Name) or playersFolder:FindFirstChild(tostring(player.UserId))
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            local isDowned = character:GetAttribute("Downed")
            local state = character:GetAttribute("State")
            local health = humanoid and humanoid.Health or 100
            if health <= 0 or isDowned or state == "Downed" then
                table.insert(downedList, player)
            end
        end
    end
    return downedList
end

function findNearestDowned()
    local nearest = nil
    local minDist = math.huge
    local myPos = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") and lp.Character.HumanoidRootPart.Position
    if not myPos then return nil end
    local gameFolder = workspace:FindFirstChild("Game")
    local playersFolder = gameFolder and gameFolder:FindFirstChild("Players")
    if not playersFolder then return nil end
    for _, player in ipairs(getDownedPlayers()) do
        local character = playersFolder:FindFirstChild(player.Name) or playersFolder:FindFirstChild(tostring(player.UserId))
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (myPos - hrp.Position).Magnitude
                if dist < minDist then minDist = dist; nearest = player end
            end
        end
    end
    return nearest
end

function pressE()
    pcall(function()
        local vim = game:GetService("VirtualInputManager")
        vim:SendKeyEvent(true, Enum.KeyCode.E, false, nil)
        task.wait(0.1)
        vim:SendKeyEvent(false, Enum.KeyCode.E, false, nil)
    end)
end

function startAutoRescue()
    if rescueConnection then rescueConnection:Disconnect() end
    print("[自动救助] 启动救助监控...")
    rescueConnection = RunService.Heartbeat:Connect(function()
        if not autoRescueEnabled then return end
        if isRescuing then return end

        -- 🔥 检查自身状态：无角色、已死亡、已倒地时不执行救助
        if not lp.Character then return end
        local myHumanoid = lp.Character:FindFirstChild("Humanoid")
        if not myHumanoid then return end
        if myHumanoid.Health <= 0 then return end
        local myState = lp.Character:GetAttribute("State") or ""
        local myDowned = lp.Character:GetAttribute("Downed")
        if myDowned or myState == "Downed" or myState == "Dead" then
            return
        end

        local downedPlayer = findNearestDowned()
        if downedPlayer then print("[自动救助] 发现倒地玩家:", downedPlayer.Name) end
        if not downedPlayer then return end

        isRescuing = true
        task.spawn(function()
            local targetCharacter = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Players") and (workspace.Game.Players:FindFirstChild(downedPlayer.Name) or workspace.Game.Players:FindFirstChild(tostring(downedPlayer.UserId)))
            if targetCharacter then
                local targetHRP = targetCharacter:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        print("[自动救助] 传送到", downedPlayer.Name, "身边")
                        lp.Character.HumanoidRootPart.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
                        task.wait(0.01)
                        lp.Character.HumanoidRootPart.CFrame = CFrame.lookAt(lp.Character.HumanoidRootPart.Position, targetHRP.Position)
                        task.wait(0.05)
                        print("[自动救助] 按下 E 键救助")
                        pressE()
                        showNotice("🚑 正在救助 " .. downedPlayer.Name, true)
                        task.wait(0.05)
                    end
                end
            end
            isRescuing = false
        end)
    end)
    print("[自动救助] 监控已启动")
end

function stopAutoRescue()
    if rescueConnection then rescueConnection:Disconnect(); rescueConnection = nil; print("[自动救助] 监控已停止") end
    isRescuing = false
end

function toggleAutoRescue()
    autoRescueEnabled = not autoRescueEnabled
    print("[自动救助] 状态切换为:", autoRescueEnabled and "开启" or "关闭")
    if autoRescueEnabled then
        startAutoRescue()
        showNotice("✅ 自动救助已开启", true)
    else
        stopAutoRescue()
        showNotice("❌ 自动救助已关闭", true)
    end
end

