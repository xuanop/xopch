    local cosmeticsFolder = ReplicatedStorage:FindFirstChild("Items") and ReplicatedStorage.Items:FindFirstChild("Cosmetics")
    if not cosmeticsFolder then
        warn("[MyCommander] 找不到 Cosmetics 文件夹")
        return
