-- 内置 HTTP 请求函数
local function broadcastHttpRequest(method, url, body)
    local req = syn and syn.request or http_request or request or (http and http.request)
    if not req then warn("[广播] 找不到 HTTP 请求函数"); return nil end
    local jsonBody = nil
    if body then
        local parts = {}
        for k, v in pairs(body) do
            local valueStr
            if type(v) == "string" then valueStr = '"' .. v:gsub('"', '\\"') .. '"'
            elseif type(v) == "number" then valueStr = tostring(v)
            elseif type(v) == "boolean" then valueStr = v and "true" or "false"
            else valueStr = '""' end
            table.insert(parts, '"' .. k .. '":' .. valueStr)
        end
        jsonBody = "{" .. table.concat(parts, ",") .. "}"
    end
    local success, result = pcall(function()
        return req({
            Url = url,
            Method = method,
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonBody,
            Timeout = 10
        })
    end)
    if success and result then return result
    else warn("[广播] HTTP 请求失败:", result); return nil end
end

