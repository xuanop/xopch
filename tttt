task.spawn(function()
    local RENAME_PAIRS = {
        { "Broom", "SwagWalk" },
        { "RockinStride", "Stride" },
        { "SnowmobileCruise", "BumperKart" },
    }

    repeat task.wait() until game:IsLoaded()
    task.wait(5)

    local items = ReplicatedStorage:FindFirstChild("Items")
    if not items then
        warn("[MyCommander] 找不到 Items，无法自动改名")
        return
    end
    local emotes = items:FindFirstChild("Emotes")
    if not emotes then
        warn("[MyCommander] 找不到 Emotes，无法自动改名")
        return
    end

    print("[MyCommander] 当前 Emotes 物品:")
    for _, v in ipairs(emotes:GetChildren()) do
        print("  - " .. v.Name)
    end

    local function findItem(name)
        local variants = {
            name,
            name:lower(),
            name:upper(),
            name:gsub("^%l", string.upper),
            name:gsub(" ", ""),
        }
        for _, v in ipairs(variants) do
            local item = emotes:FindFirstChild(v)
            if item then return item end
        end
        return nil
    end

    local function renameSingle(sourceName, targetName)
        local sourceItem = findItem(sourceName)
        if not sourceItem then
            warn("[MyCommander] 找不到来源表情:", sourceName, "，跳过此项")
            return
        end

        local targetItem = findItem(targetName)
        if targetItem and targetItem ~= sourceItem then
            warn("[MyCommander] 目标名称", targetName, "已被其他物品使用，可能无法改名")
        end

        local maxRetries = 5
        for retry = 1, maxRetries do
            local success, err = pcall(function()
                sourceItem.Name = targetName
            end)
            if success then
                print("[MyCommander] 成功将", sourceName, "改名为", targetName)
                return true
            else
                warn("[MyCommander] 改名失败 (尝试", retry, "/", maxRetries, "):", err)
                task.wait(2)
            end
        end

        warn("[MyCommander] 改名失败 (已达最大重试次数):", sourceName, "→", targetName)
        return false
    end

    for i, pair in ipairs(RENAME_PAIRS) do
        local source, target = pair[1], pair[2]
        if source and target then
            print(string.format("[MyCommander] 处理第 %d 组: %s → %s", i, source, target))
            renameSingle(source, target)
            task.wait(1)
        else
            warn("[MyCommander] 第", i, "组无效，跳过")
        end
    end

    print("[MyCommander] 所有改名操作已完成")
end)

